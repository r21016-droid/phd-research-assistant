# Copy this file to ".env" and fill in your keys.

# --- Required for all tabs ---
OPENAI_API_KEY=sk-your-key-here

# --- Tab 2 (Literature Explorer) ---
# Optional — raises Semantic Scholar rate limits. Get one free at:
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# --- Tab 5 (Zotero Chat — RAG) ---
# Pinecone — sign up free at https://pinecone.io, then copy from
# https://app.pinecone.io/-/keys
PINECONE_API_KEY=

# Zotero — see ZOTERO_PINECONE_SETUP.md for where to find these.
# User ID: https://www.zotero.org/settings/keys (under "Your userID")
# API key: https://www.zotero.org/settings/keys/new
ZOTERO_USER_ID=
ZOTERO_API_KEY=
